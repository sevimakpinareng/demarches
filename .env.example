# PostgreSQL
POSTGRES_USER=demarches
POSTGRES_PASSWORD=changeme
POSTGRES_DB=demarches
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Embedding modeli (hafta 2)
# Alternatif: intfloat/multilingual-e5-large (daha iyi, 560MB)
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_BATCH_SIZE=32

# Mistral AI (sonraki haftalarda kullanılacak)
MISTRAL_API_KEY=your_api_key_here
